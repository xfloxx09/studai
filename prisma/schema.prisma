generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ScrapedVideo {
  id        String   @id @default(uuid())
  platform  String
  title     String
  url       String
  score     Int
  views     Int
  likes     Int
  comments  Int
  createdAt DateTime @default(now())
}

model Project {
  id           String   @id @default(uuid())
  title        String
  narrative    String
  selectedVideos Json
  status       String
  createdAt    DateTime @default(now())
}

model PublishingConnection {
  id          String   @id
  platform    String
  connected   Boolean  @default(false)
  credentials Json?
}
